generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  firstName   String?
  lastName    String?
  username    String   @unique
  email       String?  @unique
  phoneNumber String?  @unique
  password    String
  role        UserRole @default(USER)
  description String?

  timezone     String?
  isBanned     Boolean   @default(false)
  lastActiveAt DateTime?

  mediaId String?
  profPic Media?  @relation(fields: [mediaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ConversationMember ConversationMember[]
  MessageReaction    MessageReaction[]
  MessageSeen        MessageSeen[]
  ActionLog          ActionLog[]

  sentMessages      Message[] @relation("MessageSender")
  forwardedMessages Message[] @relation("MessageForwardedFrom")
}

model Conversation {
  id          String           @id @default(uuid())
  type        ConversationType @default(ONE_TO_ONE)
  name        String?
  description String?

  mediaId  String?
  chatIcon Media?  @relation(fields: [mediaId], references: [id])

  isArchived Boolean @default(false)

  Message            Message[]
  ConversationMember ConversationMember[]
}

model ConversationMember {
  id             String           @default(uuid())
  userId         String
  conversationId String
  role           ConversationRole @default(MEMBER)
  joinedAt       DateTime         @default(now())

  user         User         @relation(fields: [userId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@id([userId, conversationId])
}

model Message {
  id        String             @id @default(uuid())
  type      MessageContentType @default(MESSAGE_TEXT)
  content   String?
  isDeleted Boolean            @default(false)
  isEdited  Boolean            @default(false)
  isPinned  Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversationId             String?
  mediaId                    String?
  senderId                   String?
  forwardedFromId            String?
  replyToId                  String?
  forwardedOriginalSenderId  String?
  forwardedOriginalCreatedAt DateTime?

  conversation            Conversation? @relation(fields: [conversationId], references: [id])
  media                   Media?        @relation(fields: [mediaId], references: [id])
  sender                  User?         @relation("MessageSender", fields: [senderId], references: [id])
  forwardedOriginalSender User?         @relation("MessageForwardedFrom", fields: [forwardedOriginalSenderId], references: [id])
  forwardedFrom           Message?      @relation("Forward", fields: [forwardedFromId], references: [id])
  replyTo                 Message?      @relation("Reply", fields: [replyToId], references: [id])

  forwardedTo Message[] @relation("Forward")
  replies     Message[] @relation("Reply")

  MessageReaction    MessageReaction[]
  MessageEditHistory MessageEditHistory[]
  MessageSeen        MessageSeen[]
}

model MessageEditHistory {
  id        String             @id @default(uuid())
  type      MessageContentType @default(MESSAGE_TEXT)
  messageId String
  content   String
  editedAt  DateTime           @default(now())

  message Message @relation(fields: [messageId], references: [id])
}

model MessageReaction {
  messageId String
  userId    String
  emoji     String?

  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@id([messageId, userId])
}

model MessageSeen {
  messageId String
  userId    String
  seenAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  message Message @relation(fields: [messageId], references: [id])

  @@id([userId, messageId])
}

model ActionLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entityId  String?
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Media {
  id           String          @id @default(uuid())
  url          String          @unique
  originalName String?
  type         StoredMediaType
  size         Int
  mimeType     String

  users         User[]
  conversations Conversation[]
  messages      Message[]
}

enum ConversationType {
  ONE_TO_ONE
  GROUP
}

enum MessageContentType {
  MESSAGE_TEXT
  MESSAGE_IMAGE
  MESSAGE_VIDEO
  MESSAGE_AUDIO
}

enum ConversationRole {
  MEMBER
  ADMIN
  OWNER
}

enum UserRole {
  USER
  MODERATOR
  ANALYTICS
  ADMIN
  CREATOR
}

enum StoredMediaType {
  MEDIA_IMAGE
  MEDIA_VIDEO
  MEDIA_AUDIO
  MEDIA_DOCUMENT
  MEDIA_OTHER
}
